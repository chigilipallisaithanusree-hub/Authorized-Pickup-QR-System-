# Backend Configuration Environment Variables
# Copy this file to .env and configure values for production/local deployment

# Flask Security Secret Key (must be random characters)
SECRET_KEY=super-secret-auth-key-change-in-prod

# Database configurations (MySQL setup)
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=authorized_pickup

# Database URL (Overrides separate db fields above if set)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/authorized_pickup

# Force SQLite Fallback (useful for local development without running MySQL)
USE_SQLITE=True

# AES-256 Key for Secure QR code token encryption
# Must be a 32-byte URL-safe base64 string
AES_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# SMTP Server Configurations for Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SENDER=safety@school.edu
